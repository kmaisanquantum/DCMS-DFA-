# ── Copy this to .env and fill in values ──
# Used by docker-compose.yml

# Security (CHANGE THESE IN PRODUCTION)
QR_HASH_SECRET=change-this-to-a-long-random-string-in-production

# Email / SMTP
SMTP_HOST=smtp.example.gov.pg
SMTP_PORT=587
SMTP_USER=noreply@dfa.gov.pg
SMTP_PASS=your-smtp-password

# URLs (update for your deployment domain)
PUBLIC_BASE_URL=https://dcms.dfa.gov.pg
FRONTEND_URL=https://dcms.dfa.gov.pg
REACT_APP_API_URL=https://dcms.dfa.gov.pg/api
